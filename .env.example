ENV=development

# HTTP server
PORT=8080
HTTP_READ_TIMEOUT=10s
HTTP_WRITE_TIMEOUT=15s
HTTP_IDLE_TIMEOUT=60s
HTTP_REQUEST_TIMEOUT=30s
HTTP_SHUTDOWN_TIMEOUT=15s

# MongoDB
MONGO_URI=mongodb://localhost:27017
MONGO_DB=cannect
MONGO_CONNECT_TIMEOUT=10s
MONGO_MAX_POOL_SIZE=100
MONGO_MIN_POOL_SIZE=2

# Redis (sessions / cache)
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# Auth (JWT). Set JWT_SECRET to the same value as the web NEXTAUTH_SECRET to
# share tokens between services.
JWT_SECRET=your-secret-key-here
ACCESS_TOKEN_TTL=168h        # 7d
VERIFICATION_CODE_TTL=1m     # email / reset / 2FA code lifetime

# Google sign-in (enabled only when CLIENT_ID + CLIENT_SECRET are set).
# Google verifies identity; a code is then emailed as the second factor.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost:8080/auth/callback/google
# Where the browser is sent after the callback to enter the emailed code.
# Empty => the callback returns JSON instead of redirecting.
GOOGLE_POST_AUTH_URL=

# Admin second factor — Telegram OIDC (OpenID Connect, Auth Code + PKCE, RS256).
# Enabled when CLIENT_ID + CLIENT_SECRET are set. Create them in
# @BotFather → Bot Settings → Web Login and register the redirect URL there.
TELEGRAM_OIDC_ISSUER=https://oauth.telegram.org
TELEGRAM_OIDC_CLIENT_ID=
TELEGRAM_OIDC_CLIENT_SECRET=
TELEGRAM_OIDC_REDIRECT_URL=http://localhost:8080/admin/auth/oidc/callback
# Where the callback redirects after success (token in #fragment). Empty => JSON.
TELEGRAM_OIDC_POST_AUTH_URL=
# Explicit Telegram OIDC endpoints (no discovery document is published).
TELEGRAM_OIDC_AUTH_URL=https://oauth.telegram.org/auth
TELEGRAM_OIDC_TOKEN_URL=https://oauth.telegram.org/token
TELEGRAM_OIDC_JWKS_URI=https://oauth.telegram.org/.well-known/jwks.json

# Logging
LOG_LEVEL=info
LOG_FORMAT=json
